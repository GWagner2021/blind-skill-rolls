<div class="bsr-ts__window">
  <nav class="bsr-ts__tabs">
    <button type="button" class="bsr-ts__tab {{#if (eq activeTab 'summary')}}is-active{{/if}}" data-tab="summary">Summary</button>
    <button type="button" class="bsr-ts__tab {{#if (eq activeTab 'problems')}}is-active{{/if}}" data-tab="problems">Problems</button>
    <button type="button" class="bsr-ts__tab {{#if (eq activeTab 'all')}}is-active{{/if}}" data-tab="all">All Modules</button>
  </nav>

  <section class="bsr-ts__body">

    {{#if (eq activeTab 'summary')}}
      <div class="bsr-ts__infoStrip">
        {{#each summaryRows}}
          <div class="bsr-ts__infoItem">
            <span class="bsr-ts__infoLabel">{{label}}</span>
            <span class="bsr-ts__infoValue">{{value}}</span>
          </div>
        {{/each}}
      </div>

      <div class="bsr-ts__card">
        <h2 class="bsr-ts__sectionTitle">BSR Settings</h2>

        {{#each settingsLayout}}
          {{#if paired}}
            <div class="bsr-ts__pairRow">
              {{#if left}}
                <div class="bsr-ts__group">
                  {{#if left.headerItem}}
                    <div class="bsr-ts__colHeader">
                      <span class="bsr-ts__colHeaderName">{{left.headerItem.name}}</span>
                      <span class="bsr-ts__colHeaderValue">{{left.headerItem.value}}</span>
                    </div>
                  {{/if}}
                  <div class="bsr-ts__groupHeader {{#if left.headerItem}}bsr-ts__groupHeader--below{{/if}}">{{left.label}} {{#if left.tag}}<span class="bsr-ts__groupTag">{{left.tag}}</span>{{/if}}</div>
                  <table class="bsr-ts__table bsr-ts__table--fixed">
                    <thead><tr><th class="bsr-ts__colSetting">Setting</th><th class="bsr-ts__colValue">Value</th></tr></thead>
                    <tbody>
                      {{#each left.items}}
                        <tr>
                          <td class="bsr-ts__settingName">{{name}}</td>
                          <td class="bsr-ts__settingValue">{{value}}</td>
                        </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              {{/if}}
              {{#if right}}
                <div class="bsr-ts__group">
                  {{#if right.headerItem}}
                    <div class="bsr-ts__colHeader">
                      <span class="bsr-ts__colHeaderName">{{right.headerItem.name}}</span>
                      <span class="bsr-ts__colHeaderValue">{{right.headerItem.value}}</span>
                    </div>
                  {{/if}}
                  <div class="bsr-ts__groupHeader {{#if right.headerItem}}bsr-ts__groupHeader--below{{/if}}">{{right.label}} {{#if right.tag}}<span class="bsr-ts__groupTag">{{right.tag}}</span>{{/if}}</div>
                  <table class="bsr-ts__table bsr-ts__table--fixed">
                    <thead><tr><th class="bsr-ts__colSetting">Setting</th><th class="bsr-ts__colValue">Value</th></tr></thead>
                    <tbody>
                      {{#each right.items}}
                        <tr>
                          <td class="bsr-ts__settingName">{{name}}</td>
                          <td class="bsr-ts__settingValue">{{value}}</td>
                        </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              {{/if}}
            </div>
          {{else}}
            <div class="bsr-ts__group">
              <div class="bsr-ts__groupHeader">{{group.label}} {{#if group.tag}}<span class="bsr-ts__groupTag">{{group.tag}}</span>{{/if}}</div>
              <table class="bsr-ts__table bsr-ts__table--fixed">
                <thead><tr><th class="bsr-ts__colSetting">Setting</th><th class="bsr-ts__colValue">Value</th></tr></thead>
                <tbody>
                  {{#each group.items}}
                    <tr>
                      <td class="bsr-ts__settingName">{{name}}</td>
                      <td class="bsr-ts__settingValue">{{value}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{/if}}
        {{/each}}

        {{#if midiSettingsRows.length}}
          <div class="bsr-ts__group">
            <div class="bsr-ts__groupHeader">MidiQOL Settings</div>

            <table class="bsr-ts__table bsr-ts__table--fixed">
              <thead>
                <tr>
                  <th class="bsr-ts__colSetting">Setting</th>
                  <th class="bsr-ts__colValue">Value</th>
                </tr>
              </thead>
              <tbody>
                {{#each midiSettingsRows}}
                  <tr>
                    <td class="bsr-ts__settingName">{{label}}</td>
                    <td class="bsr-ts__settingValue">{{value}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{/if}}
      </div>
    {{/if}}

    {{#if (eq activeTab 'problems')}}
      <div class="bsr-ts__card">
        <h2 class="bsr-ts__sectionTitle">BSR &amp; Compatibility Module Errors</h2>

        <p class="bsr-ts__muted">
          Captures errors from BSR and known compatibility modules
          (lib-wrapper, midi-qol, dice-so-nice, combat-tracker-dock).
          Reproduce the issue, then check here.
        </p>

        <table class="bsr-ts__table">
          <thead>
            <tr>
              <th style="width:150px;">Time</th>
              <th style="width:70px;">Level</th>
              <th style="width:120px;">Origin</th>
              <th style="width:130px;">Source</th>
              <th>Message</th>
            </tr>
          </thead>
          <tbody>
            {{#each problemsRows}}
              <tr>
                <td class="bsr-ts__mono">{{time}}</td>
                <td class="bsr-ts__mono">{{level}}</td>
                <td class="bsr-ts__mono">{{origin}}</td>
                <td class="bsr-ts__mono">{{source}}</td>
                <td class="bsr-ts__mono">{{message}}</td>
              </tr>
            {{/each}}

            {{#unless problemsRows.length}}
              <tr>
                <td colspan="5" class="bsr-ts__muted">No errors captured yet.</td>
              </tr>
            {{/unless}}
          </tbody>
        </table>

        <p class="bsr-ts__muted">Use "Export Data" to include captured logs in the JSON report.</p>
      </div>
    {{/if}}

    {{#if (eq activeTab 'all')}}
      <div class="bsr-ts__card">
        <h2 class="bsr-ts__sectionTitle">All Installed Modules</h2>
        <table class="bsr-ts__table">
          <thead>
            <tr>
              <th>Module ID</th>
              <th style="width:70px;">Status</th>
              <th>Title</th>
              <th style="width:80px;">Version</th>
              <th style="width:80px;">Foundry</th>
            </tr>
          </thead>
          <tbody>
            {{#each allModulesRows}}
              <tr>
                <td class="bsr-ts__mono">{{id}}</td>
                <td>{{#if active}}<span class="bsr-ts__badge bsr-ts__badge--active">active</span>{{else}}<span class="bsr-ts__badge bsr-ts__badge--inactive">off</span>{{/if}}</td>
                <td>{{title}}</td>
                <td class="bsr-ts__mono">{{version}}</td>
                <td class="bsr-ts__mono">{{foundry}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

  </section>

  <footer class="bsr-ts__footer">
    <button type="button" data-action="reload"><i class="fas fa-sync"></i> Reload</button>
    <button type="button" data-action="clearLog"><i class="fas fa-trash"></i> Clear Log</button>
    <button type="button" data-action="export"><i class="fas fa-file-export"></i> Export Data</button>
  </footer>

  <textarea data-json class="bsr-ts__hiddenJson">{{reportJson}}</textarea>
</div>
