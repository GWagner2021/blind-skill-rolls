<form class="bsr-form">
  <p class="bsr-intro">{{labels.pageIntro}}</p>

  <div class="bsr-card">
    <div class="bsr-card__header">
      <span class="bsr-card__title"><i class="fa-solid fa-dice-d20"></i> {{labels.skills}}</span>
      <div class="bsr-card__actions">
        <button type="button" class="bsr-btn bsr-btn-sm" data-action="all">{{labels.all}}</button>
        <button type="button" class="bsr-btn bsr-btn-sm" data-action="none">{{labels.none}}</button>
        <button type="button" class="bsr-btn bsr-btn-sm" data-action="defaults">{{labels.defaults}}</button>
      </div>
    </div>
    <div class="bsr-card__body">
      <label class="bsr-form-check">
        <input type="checkbox" name="enabled" {{#if enabled}}checked{{/if}}>
        <span>{{labels.enabledName}}</span>
      </label>
      <label class="bsr-form-check">
        <input type="checkbox" name="blindRollersChat" {{#if blindRollersChat}}checked{{/if}}>
        <span>{{labels.blindRollersChatName}}</span>
      </label>
      <div class="bsr-skill-grid">
        <strong></strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.blind}}</strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.private}}</strong>
        <span class="bsr-skill-grid__sep"></span>
        <strong></strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.blind}}</strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.private}}</strong>
        {{#each skillGridRows}}
          <span class="bsr-skill-grid__name">{{left.label}}</span>
          <label class="bsr-skill-grid__cb"><input type="checkbox" data-skill="{{left.key}}" data-mode="blind" {{#if left.blind}}checked{{/if}} {{#if left.private}}disabled{{/if}}></label>
          <label class="bsr-skill-grid__cb"><input type="checkbox" data-skill="{{left.key}}" data-mode="private" {{#if left.private}}checked{{/if}} {{#if left.blind}}disabled{{/if}}></label>
          <span class="bsr-skill-grid__sep"></span>
          {{#if right}}
            <span class="bsr-skill-grid__name">{{right.label}}</span>
            <label class="bsr-skill-grid__cb"><input type="checkbox" data-skill="{{right.key}}" data-mode="blind" {{#if right.blind}}checked{{/if}} {{#if right.private}}disabled{{/if}}></label>
            <label class="bsr-skill-grid__cb"><input type="checkbox" data-skill="{{right.key}}" data-mode="private" {{#if right.private}}checked{{/if}} {{#if right.blind}}disabled{{/if}}></label>
          {{else}}
            <span></span><span></span><span></span>
          {{/if}}
        {{/each}}
      </div>
    </div>
  </div>

  <div class="bsr-card">
    <div class="bsr-card__header">
      <span class="bsr-card__title"><i class="fa-solid fa-shield-halved"></i> {{labels.saves}}</span>
      <div class="bsr-card__actions">
        <button type="button" class="bsr-btn bsr-btn-sm" data-action="allSaves">{{labels.allSaves}}</button>
        <button type="button" class="bsr-btn bsr-btn-sm" data-action="noneSaves">{{labels.noneSaves}}</button>
      </div>
    </div>
    <div class="bsr-card__body">
      <label class="bsr-form-check">
        <input type="checkbox" name="savesEnabled" {{#if savesEnabled}}checked{{/if}}>
        <span>{{labels.savesEnabledName}}</span>
      </label>
      <label class="bsr-form-check">
        <input type="checkbox" name="blindRollersSaveChat" {{#if blindRollersSaveChat}}checked{{/if}}>
        <span>{{labels.blindRollersSaveChatName}}</span>
      </label>
      <div class="bsr-skill-grid">
        <strong></strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.blind}}</strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.private}}</strong>
        <span class="bsr-skill-grid__sep"></span>
        <strong></strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.blind}}</strong>
        <strong class="bsr-skill-grid__colhdr">{{labels.private}}</strong>
        {{#each saveGridRows}}
          <span class="bsr-skill-grid__name">{{left.label}}</span>
          <label class="bsr-skill-grid__cb"><input type="checkbox" data-save="{{left.key}}" data-mode="blind" {{#if left.blind}}checked{{/if}} {{#if left.private}}disabled{{/if}}></label>
          <label class="bsr-skill-grid__cb"><input type="checkbox" data-save="{{left.key}}" data-mode="private" {{#if left.private}}checked{{/if}} {{#if left.blind}}disabled{{/if}}></label>
          <span class="bsr-skill-grid__sep"></span>
          {{#if right}}
            <span class="bsr-skill-grid__name">{{right.label}}</span>
            <label class="bsr-skill-grid__cb"><input type="checkbox" data-save="{{right.key}}" data-mode="blind" {{#if right.blind}}checked{{/if}} {{#if right.private}}disabled{{/if}}></label>
            <label class="bsr-skill-grid__cb"><input type="checkbox" data-save="{{right.key}}" data-mode="private" {{#if right.private}}checked{{/if}} {{#if right.blind}}disabled{{/if}}></label>
          {{else}}
            <span></span><span></span><span></span>
          {{/if}}
        {{/each}}
      </div>
    </div>
  </div>

  <footer class="bsr-footer">
    <button type="button" class="bsr-btn" data-action="cancel">{{labels.cancel}}</button>
    <button type="submit" class="bsr-btn bsr-btn-primary" data-action="save">{{labels.save}}</button>
  </footer>
</form>
